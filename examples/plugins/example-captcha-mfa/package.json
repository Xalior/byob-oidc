{
    "name": "byob-plugin-example-captcha-mfa",
    "version": "1.0.0",
    "description": "Example BYOB-OIDC MFA plugin: random question-based captcha",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js",
        "dev": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --watch",
        "clean": "rm -rf dist"
    },
    "devDependencies": {
        "@byob-oidc/plugin-types": "file:../../../packages/plugin-types",
        "@types/node": "^20.19.0",
        "esbuild": "^0.25.0",
        "typescript": "^5.9.3"
    },
    "byob-oidc": {
        "pluginType": "mfa",
        "requiredEnv": [],
        "minCoreVersion": "0.3.1"
    }
}
