{
    "name": "byob-plugin-example-csv-provider",
    "version": "1.0.0",
    "description": "Example BYOB-OIDC provider plugin: CSV flat-file with bcrypt passwords",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:bcryptjs",
        "dev": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:bcryptjs --watch",
        "clean": "rm -rf dist"
    },
    "devDependencies": {
        "@byob-oidc/plugin-types": "file:../../../packages/plugin-types",
        "@types/node": "^20.19.0",
        "esbuild": "^0.25.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "bcryptjs": "^3.0.3"
    },
    "byob-oidc": {
        "pluginType": "provider",
        "requiredEnv": ["CSV_USERS_FILE"],
        "minCoreVersion": "0.3.1"
    }
}
