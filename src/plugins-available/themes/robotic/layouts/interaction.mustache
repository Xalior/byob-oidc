<div>
    <h1>AUTHORIZATION REQUEST</h1>
    <p>EXTERNAL MODULE <strong>{{client.clientName}}</strong> IS REQUESTING ACCESS TO YOUR DATA CORE.</p>
    
    {{#client.logoUri}}
        <div style="text-align: center; margin: 20px 0;">
            <img src="{{client.logoUri}}" style="max-width: 100px; border: 1px solid var(--border-color);">
        </div>
    {{/client.logoUri}}

    <h3>REQUESTED PERMISSIONS:</h3>
    <ul>
        {{#noMissingDetails}}
            <li>RE-CONFIRM PREVIOUS AUTHORIZATION</li>
        {{/noMissingDetails}}

        {{#filteredMissingOIDCScope}}
            <li>DATA SCOPES:</li>
            <ul>
            {{#filteredMissingOIDCScope}}
                <li>{{.}}</li>
            {{/filteredMissingOIDCScope}}
            </ul>
        {{/filteredMissingOIDCScope}}

        {{#filteredMissingOIDCClaims}}
            <li>DATA CLAIMS:</li>
            <ul>
                {{#filteredMissingOIDCClaims}}
                    <li>{{.}}</li>
                {{/filteredMissingOIDCClaims}}
            </ul>
        {{/filteredMissingOIDCClaims}}

        {{#missingResourceScopes}}
            {{#eachMissingResourceScope}}
                <li>RESOURCE [{{indicator}}]:</li>
                <ul>
                    {{#scopes}}
                        <li>{{.}}</li>
                    {{/scopes}}
                </ul>
            {{/eachMissingResourceScope}}
        {{/missingResourceScopes}}

        {{#isOfflineAccessRequested}}
            <li>
                OFFLINE DATA PERSISTENCE REQUESTED
                {{#hasPreviouslyGrantedOfflineAccess}}
                    (PREVIOUSLY AUTHORIZED)
                {{/hasPreviouslyGrantedOfflineAccess}}
            </li>
        {{/isOfflineAccessRequested}}
    </ul>

    <form autocomplete="off" action="/interaction/{{uid}}/confirm" method="post">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <button autofocus type="submit">AUTHORIZE ACCESS</button>
    </form>
    <form action="/interaction/{{ uid }}/abort" method="GET">
        <button type="submit" style="border-color: #ff0000; color: #ff0000;">DENY ACCESS</button>
    </form>
</div>
