        <div>
            <label for="display_name">DISPLAY NAME:</label><br>
            <input type="text" id="display_name" name="display_name" value="{{user.display_name}}" required>
        </div>
        <button type="submit">SYNCHRONIZE DATA</button>
    </form>
</div>
